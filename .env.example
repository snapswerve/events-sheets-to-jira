# ─── Data Source ───
# Option A: Google Sheets API (recommended)
GOOGLE_SHEETS_MODE=false
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-from-the-url
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account-key.json

# Option B: Local xlsx file (fallback)
EVENTING_PLAN_PATH=./data/eventing-plan.xlsx

# ─── Jira Cloud (for --live mode) ───
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=TRACK
JIRA_EPIC_KEY=TRACK-123
